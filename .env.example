## Frontend (Vite)
# Your Supabase project URL, e.g. https://xxxx.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon public key (safe for frontend)
VITE_SUPABASE_ANON_KEY=

# Optional: Edge Functions prefix (defaults to "make-server-ed0cf80c")
VITE_SUPABASE_FUNCTIONS_PREFIX=make-server-ed0cf80c

## Supabase Edge Functions (Deno runtime)
# Used when deploying functions in `src/supabase/functions/server/`
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

